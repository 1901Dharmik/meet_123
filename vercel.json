{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/artifacts/skillrapido/dist/public/$1",
      "check": true
    },
    {
      "source": "/(.*)",
      "destination": "/artifacts/skillrapido/dist/public/index.html"
    }
  ]
}
